<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_welcome_dark"
    android:fitsSystemWindows="true">

    <!-- App Logo at top -->
    <ImageView
        android:id="@+id/ivWelcomeLogo"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:src="@drawable/ic_welcome_logo"
        android:contentDescription="@string/app_name"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Abstract Illustration in center -->
    <ImageView
        android:id="@+id/ivWelcomeIllustration"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:src="@drawable/ic_welcome_illustration"
        android:contentDescription="@string/welcome_illustration_desc"
        android:alpha="0.85"
        app:layout_constraintTop_toBottomOf="@id/ivWelcomeLogo"
        app:layout_constraintBottom_toTopOf="@id/tvWelcomeTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintVertical_bias="0.45" />

    <!-- Welcome Title — large, bold, white -->
    <TextView
        android:id="@+id/tvWelcomeTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/welcome_title"
        android:textColor="#FFFFFF"
        android:textSize="36sp"
        android:fontFamily="sans-serif-medium"
        android:textStyle="bold"
        android:letterSpacing="-0.02"
        android:gravity="center"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/ivWelcomeIllustration"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Subtitle — muted white -->
    <TextView
        android:id="@+id/tvWelcomeSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/welcome_subtitle"
        android:textColor="#8A9A9A"
        android:textSize="14sp"
        android:fontFamily="sans-serif"
        android:gravity="center"
        android:lineSpacingExtra="3dp"
        android:layout_marginTop="10dp"
        android:paddingStart="40dp"
        android:paddingEnd="40dp"
        app:layout_constraintTop_toBottomOf="@id/tvWelcomeTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Get Started Button — white pill -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnGetStarted"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="@string/get_started"
        android:textColor="#0A0F0F"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textAllCaps="false"
        android:fontFamily="sans-serif-medium"
        android:background="@drawable/bg_welcome_btn_primary"
        android:layout_marginStart="28dp"
        android:layout_marginEnd="28dp"
        android:layout_marginBottom="12dp"
        android:stateListAnimator="@null"
        android:elevation="0dp"
        app:backgroundTint="@null"
        app:cornerRadius="28dp"
        app:rippleColor="#334ED8E2"
        app:layout_constraintBottom_toTopOf="@id/tvAlreadyHaveAccount"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Already have account — dark pill button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/tvAlreadyHaveAccount"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="@string/already_have_account"
        android:textColor="#C0D0D0"
        android:textSize="15sp"
        android:textAllCaps="false"
        android:fontFamily="sans-serif-medium"
        android:background="@drawable/bg_welcome_btn_secondary"
        android:layout_marginStart="28dp"
        android:layout_marginEnd="28dp"
        android:layout_marginBottom="16dp"
        android:stateListAnimator="@null"
        android:elevation="0dp"
        app:backgroundTint="@null"
        app:cornerRadius="28dp"
        app:icon="@drawable/ic_email"
        app:iconGravity="textStart"
        app:iconTint="#C0D0D0"
        app:iconSize="20dp"
        app:iconPadding="8dp"
        app:rippleColor="#224ED8E2"
        app:layout_constraintBottom_toTopOf="@id/tvTerms"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Terms text at the bottom -->
    <TextView
        android:id="@+id/tvTerms"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/welcome_terms"
        android:textColor="#4A5A5A"
        android:textSize="11sp"
        android:fontFamily="sans-serif"
        android:gravity="center"
        android:lineSpacingExtra="2dp"
        android:paddingStart="40dp"
        android:paddingEnd="40dp"
        android:layout_marginBottom="28dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
